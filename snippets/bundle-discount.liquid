{% endcomment %}
<script>
  window.bundleSettings = [
    {% assign has_prev = false %}
    {% for i in (1..6) %}
      {% assign bid_key = 'bundle_' | append: i | append: '_id' %}
      {% assign v1_key  = 'bundle_' | append: i | append: '_variant_1' %}
      {% assign v2_key  = 'bundle_' | append: i | append: '_variant_2' %}

      {% if settings[bid_key] != blank and settings[v1_key] != blank and settings[v2_key] != blank %}
        {% if has_prev %},{% endif %}
        {
          "bundleId":   {{ settings[bid_key] | json }},
          "variantId1": {{ settings[v1_key]  | json }},
          "variantId2": {{ settings[v2_key]  | json }}
        }
        {% assign has_prev = true %}
      {% endif %}
    {% endfor %}
  ];
</script>
<script src="{{ 'bundle-discount.js' | asset_url }}" defer></script> {% endcomment %}