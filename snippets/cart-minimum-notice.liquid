{% if settings.cart_minimum_enable %}
<style>
  .cart-min-bar {display: block;margin: 0px 0px 10px;padding: 10px;border-radius: 8px;font-size: 14px;line-height: 1.5;font-family: inherit;box-sizing: border-box;}
  cart-drawer-component.cart-drawer .cart-min-bar{position: absolute;top: 58px;left: 0;z-index: 2;width: calc(100% - 20px);}
  .cart-min-bar__row { display: flex; align-items: center; gap: 8px; }
  .cart-min-bar__icon { font-size: 16px; flex-shrink: 0; }
  .cart-min-bar__msg { flex: 1;font-size: 13px; text-align:center;}
  .cart-min-bar__track { margin-top: 5px; height: 6px; border-radius: 999px; overflow: hidden; background: {{ settings.cart_minimum_progress_bg_color }}; }
  .cart-min-bar__fill { height: 6px; border-radius: 999px; background: {{ settings.cart_minimum_progress_color }}; transition: width 0.4s ease; }
  .cart-min-bar__label { margin-top: 4px; font-size: 12px; opacity: 0.75; text-align: right; }
  cart-drawer-component.cart-drawer .cart-min-bar{margin:10px;}
  cart-drawer-component.cart-drawer .cart-drawer__header {padding-bottom: 110px !important;}
  .page-cart .cart-min-bar{max-width: 1120px;margin: 20px auto 0px;width:95%;}
  {% unless settings.cart_minimum_show_progress %}
  .cart-min-bar__track, .cart-min-bar__label { display: none !important; }
  {% endunless %}
</style>

<script>
(function () {

  var MIN_CENTS     = {{ settings.cart_minimum_amount | times: 100 }};
  var MSG_BELOW     = {{ settings.cart_minimum_message | json }};
  var MSG_REACHED   = {{ settings.cart_minimum_reached_message | json }};
  var BG_BELOW      = {{ settings.cart_minimum_bg_color | json }};
  var COLOR_BELOW   = {{ settings.cart_minimum_text_color | json }};
  var BG_REACHED    = {{ settings.cart_minimum_reached_bg_color | json }};
  var COLOR_REACHED = {{ settings.cart_minimum_reached_text_color | json }};
  var BTN_SELECTOR  = {{ settings.cart_minimum_button_selector | json }};

  var _runTimer = null;
  function scheduleRun(delay) {
    clearTimeout(_runTimer);
    _runTimer = setTimeout(run, delay || 150);
  }

  function getTotalCents() {
    var el = document.querySelector('[data-cart-subtotal]');
    if (el) {
      var val = el.getAttribute('value') || '';
      var num = parseFloat(val.replace(/[^0-9.]/g, ''));
      if (!isNaN(num) && num > 0) return Math.round(num * 100);
    }
    var aiod = document.querySelector('.csapps-cart-total');
    if (aiod) {
      var txt = aiod.textContent.trim();
      var n = parseFloat(txt.replace(/[^0-9.]/g, ''));
      if (!isNaN(n) && n > 0) return Math.round(n * 100);
    }
    return 0;
  }

  function money(cents) {
    return '$' + (cents / 100).toFixed(2).replace(/\.00$/, '');
  }

  function createBar() {
    var el = document.createElement('div');
    el.className = 'cart-min-bar';
    el.innerHTML =
        '<div class="cart-min-bar__row">'
      {% comment %} +   '<span class="cart-min-bar__icon"></span>' {% endcomment %}
      +   '<span class="cart-min-bar__msg"></span>'
      + '</div>'
      + '<div class="cart-min-bar__track">'
      +   '<div class="cart-min-bar__fill" style="width:0%"></div>'
      + '</div>'
      + '<div class="cart-min-bar__label"></div>';
    return el;
  }

  function renderBar(el, total) {
    if (total === 0) { el.style.display = 'none'; return; }
    el.style.display = 'block';
    var reached = total >= MIN_CENTS;
    var remain  = Math.max(0, MIN_CENTS - total);
    var pct     = Math.min(100, Math.round(total / MIN_CENTS * 100));
    el.style.setProperty('background', reached ? BG_REACHED : BG_BELOW, 'important');
    el.style.setProperty('color', reached ? COLOR_REACHED : COLOR_BELOW, 'important');
    {% comment %} el.querySelector('.cart-min-bar__icon').textContent = reached ? '\u2705' : '\u26A0\uFE0F'; {% endcomment %}
    el.querySelector('.cart-min-bar__fill').style.width = pct + '%';
    el.querySelector('.cart-min-bar__label').textContent = money(total) + ' / ' + money(MIN_CENTS);
    el.querySelector('.cart-min-bar__msg').textContent = reached
      ? MSG_REACHED
      : MSG_BELOW.replace('{amount}', money(remain)).replace('{minimum}', money(MIN_CENTS));
  }

  function ensureDrawerBar() {
    var drawer = document.querySelector('.cart-drawer__dialog');
    if (!drawer) return null;
    var existing = drawer.querySelector(':scope > .cart-min-bar');
    if (existing) return existing;
    var bar = createBar();
    drawer.insertBefore(bar, drawer.firstChild);
    return bar;
  }

  function ensurePageBar() {
    var page = document.querySelector('body.page-cart #MainContent');
    if (!page) return null;
    var existing = page.querySelector(':scope > .cart-min-bar');
    if (existing) return existing;
    var bar = createBar();
    page.insertBefore(bar, page.firstChild);
    return bar;
  }

  function run() {
    var total   = getTotalCents();
    var reached = total >= MIN_CENTS;
    var drawerBar = ensureDrawerBar();
    var pageBar   = ensurePageBar();
    if (drawerBar) renderBar(drawerBar, total);
    if (pageBar)   renderBar(pageBar, total);
    document.querySelectorAll(BTN_SELECTOR).forEach(function (btn) {
      btn.disabled            = !reached;
      btn.style.opacity       = reached ? '' : '0.45';
      btn.style.cursor        = reached ? '' : 'not-allowed';
      btn.style.pointerEvents = reached ? '' : 'none';
    });
  }

  function observeDrawer(drawer) {
    var obs = new MutationObserver(function (mutations) {
      for (var i = 0; i < mutations.length; i++) {
        var t = mutations[i].target;
        if (t.classList && t.classList.contains('cart-min-bar')) continue;
        if (t.closest && t.closest('.cart-min-bar')) continue;
        scheduleRun(150);
        return;
      }
    });
    obs.observe(drawer, {
      childList: true, subtree: true, characterData: true,
      attributes: true, attributeFilter: ['value', 'open']
    });
  }

  var _drawerCheck = setInterval(function () {
    var drawer = document.querySelector('.cart-drawer__dialog');
    if (drawer) {
      clearInterval(_drawerCheck);
      observeDrawer(drawer);
      run();
    }
  }, 300);

  setInterval(function () {
    var dialog = document.querySelector('.cart-drawer__dialog');
    if (dialog && dialog.hasAttribute('open')) {
      if (!dialog.querySelector(':scope > .cart-min-bar')) {
        run();
      }
    }
  }, 200);

  if (document.querySelector('body.page-cart')) {
    run();
    var _lastPrice = getTotalCents();
    setInterval(function () {
      var current = getTotalCents();
      if (current !== _lastPrice) {
        _lastPrice = current;
        run();
      }
    }, 500);
  }

  document.addEventListener('cart:updated',   function () { scheduleRun(100); });
  document.addEventListener('cart:change',    function () { scheduleRun(100); });
  document.addEventListener('on:cart:add',    function () { scheduleRun(100); });
  document.addEventListener('on:cart:change', function () { scheduleRun(100); });

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', run);
  } else {
    run();
  }

})();
</script>

{% endif %}