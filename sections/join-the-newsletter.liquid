      "id": "subtitle_font_size_mobile",
      "label": "Subtitle Font Size - Mobile",
      "min": 10,
      "max": 26,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "select",
      "id": "subtitle_line_height",
      "label": "Subtitle Line Height",
      "options": [
        { "value": "1.3", "label": "1.3" },
        { "value": "1.5", "label": "1.5" },
        { "value": "1.7", "label": "1.7" },
