      "step": 1,
      "unit": "px",
      "default": 15
    },
    {
      "type": "range",
      "id": "subtitle_font_size_tablet",
      "label": "Subtitle Font Size - Tablet",
      "min": 10,
      "max": 30,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
