    },
    {
      "type": "range",
      "id": "autoplay_delay",
      "label": "Autoplay Delay (ms)",
      "min": 1000,
      "max": 8000,
      "step": 500,
      "default": 4000
    },
    {
      "type": "range",
      "id": "transition_speed",
      "label": "Transition Speed (ms)",
