      "label": "Question Margin Bottom (Desktop)",
      "min": 0,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "question_margin_bottom_tablet",
      "label": "Question Margin Bottom (Tablet)",
      "min": 0,
