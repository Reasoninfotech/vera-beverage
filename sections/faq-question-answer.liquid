{% style %}

/* Desktop Styles */
.faq_section {
  padding-top: {{ section.settings.padding_top }}px;
  padding-bottom: {{ section.settings.padding_bottom }}px;
}

.faq_section .faq_question {
  color: {{ section.settings.faq_quetion_color }};
  font-size: {{ section.settings.question_font_size }}px;
  margin-bottom: {{ section.settings.question_margin_bottom }}px;
}

.faq_section .faq_answer {
  font-size: {{ section.settings.answer_font_size }}px;
  color: "{{ section.settings.faq_answer_color }}"
}

.faq_section .faq_block {
  display: flex;
  flex-direction: column;
  gap: 50px;
  max-width: 672px;
  margin: 0 auto;
}

/* Tablet Styles */
@media screen and (max-width: 1024px) and (min-width: 768px) {
  .faq_section {
    padding-top: {{ section.settings.padding_top_tablet }}px;
    padding-bottom: {{ section.settings.padding_bottom_tablet }}px;
  }
  .faq_section .faq_question {
    font-size: {{ section.settings.question_font_size_tablet }}px;
    margin-bottom: {{ section.settings.question_margin_bottom_tablet }}px;
  }
  .faq_section .faq_answer {
    font-size: {{ section.settings.answer_font_size_tablet }}px;
  }
}

/* Mobile Styles */
@media screen and (max-width: 767px) {
  .faq_section {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
  }

  .faq_section .faq_block{
    gap: 25px;
  }

  .faq_section .faq_question {
    font-size: {{ section.settings.question_font_size_mobile }}px;
    margin-bottom: {{ section.settings.question_margin_bottom_mobile }}px;
  }
  .faq_section .faq_answer {
    font-size: {{ section.settings.answer_font_size_mobile }}px;
  }
}

{% endstyle %}

<section class="faq_section">
  <div class="section section--{{ section.settings.section_width }} section-resource-list spacing-style">
    <div class="faq_block">
      {% for block in section.blocks %}
        <div class="faq_row">
          {% if block.settings.faq_question != blank %}
            <h3 class="faq_question">{{ block.settings.faq_question }}</h3>
          {% endif %}
          {% if block.settings.faq_answer != blank %}
            <div class="faq_answer">{{ block.settings.faq_answer }}</div>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>


{% schema %}
{
  "name": "Faq Section",
  "settings": [
    {
      "type": "color",
      "id": "faq_quetion_color",
      "label": "FAQ Question Color",
      "default": "#8a2d72"
    },
    {
      "type": "color",
      "id": "faq_answer_color",
      "label": "FAQ Answer Color",
      "default": "#464646"
    },
    {
      "type": "header",
      "content": "Section Padding — Desktop"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top (Desktop)",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom (Desktop)",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "header",
      "content": "Section Padding — Tablet"
    },
    {
      "type": "range",
      "id": "padding_top_tablet",
      "label": "Padding Top (Tablet)",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_tablet",
      "label": "Padding Bottom (Tablet)",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "header",
      "content": "Section Padding — Mobile"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding Top (Mobile)",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding Bottom (Mobile)",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 24
