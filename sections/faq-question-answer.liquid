      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "answer_font_size_tablet",
      "label": "Answer Font Size (Tablet)",
      "min": 12,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 15
    },
    {
      "type": "range",
      "id": "answer_font_size_mobile",
      "label": "Answer Font Size (Mobile)",
      "min": 12,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 14
