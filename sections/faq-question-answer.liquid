      "type": "range",
      "id": "question_font_size_tablet",
      "label": "Question Font Size (Tablet)",
      "min": 12,
      "max": 60,
      "step": 1,
      "unit": "px",
      "default": 22
    },
    {
      "type": "range",
      "id": "question_font_size_mobile",
      "label": "Question Font Size (Mobile)",
      "min": 12,
      "max": 60,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "header",
      "content": "FAQ Question Bottom Margin"
