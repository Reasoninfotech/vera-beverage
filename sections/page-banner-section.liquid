{% comment %}
  VERA Productive Elixir - Hero Banner Section
  Horizon Theme Compatible
  Full responsive: Mobile / Tablet / Desktop
{% endcomment %}

<style>
  #shopify-section-{{ section.id }} {
    --subtitle-color-desktop: {{ section.settings.subtitle_color_desktop }};
    --subtitle-color-tablet: {{ section.settings.subtitle_color_tablet }};
    --subtitle-color-mobile: {{ section.settings.subtitle_color_mobile }};

    --title-color-desktop: {{ section.settings.title_color_desktop }};
    --title-color-tablet: {{ section.settings.title_color_tablet }};
    --title-color-mobile: {{ section.settings.title_color_mobile }};

    --subtitle-size-desktop: {{ section.settings.subtitle_size_desktop }}px;
    --subtitle-size-tablet: {{ section.settings.subtitle_size_tablet }}px;
    --subtitle-size-mobile: {{ section.settings.subtitle_size_mobile }}px;

    --title-size-desktop: {{ section.settings.title_size_desktop }}px;
    --title-size-tablet: {{ section.settings.title_size_tablet }}px;
    --title-size-mobile: {{ section.settings.title_size_mobile }}px;

    --section-height-desktop: {{ section.settings.section_height_desktop }}px;
    --section-height-tablet: {{ section.settings.section_height_tablet }}px;
    --section-height-mobile: {{ section.settings.section_height_mobile }}px;

    --overlay-color: {{ section.settings.overlay_color }};
    --overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};

    --content-align: {{ section.settings.content_alignment }};
    --content-justify: 
      {% if section.settings.content_alignment == 'left' %}flex-start
      {% elsif section.settings.content_alignment == 'right' %}flex-end
      {% else %}center{% endif %};

    --subtitle-letter-spacing: {{ section.settings.subtitle_letter_spacing }}px;
    --title-letter-spacing: {{ section.settings.title_letter_spacing }}px;
    --subtitle-font-weight: {{ section.settings.subtitle_font_weight }};
    --title-font-weight: {{ section.settings.title_font_weight }};
  }

  .vera-hero__section {
    position: relative;
    width: 100%;
    height: var(--section-height-desktop);
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: var(--content-justify);
  }

  .vera-hero__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    z-index: 0;
  }

  .vera-hero__overlay {
    position: absolute;
    inset: 0;
    background-color: var(--overlay-color);
    opacity: var(--overlay-opacity);
    z-index: 1;
  }

  .vera-hero__content {
    position: relative;
    z-index: 2;
    text-align: var(--content-align);
    padding: 15px 30px;
    max-width: {{ section.settings.content_max_width }}px;
    {% if section.settings.content_alignment == 'center' %}
      margin: 0 auto;
    {% elsif section.settings.content_alignment == 'right' %}
      margin-right: 60px;
    {% else %}
      margin-left: 60px;
    {% endif %}

    {% if section.settings.content_bg_enabled %}
      background: {{ section.settings.content_bg_color }};
      backdrop-filter: blur({{ section.settings.content_bg_blur }}px);
      -webkit-backdrop-filter: blur({{ section.settings.content_bg_blur }}px);
      border-radius: {{ section.settings.content_bg_radius }}px;
      padding: {{ section.settings.content_padding_v }}px {{ section.settings.content_padding_h }}px;
    {% endif %}
  }

  .vera-hero__subtitle {
    display: block;
    font-size: var(--subtitle-size-desktop);
    color: var(--subtitle-color-desktop);
    letter-spacing: var(--subtitle-letter-spacing);
    font-weight: var(--subtitle-font-weight);
    text-transform: {{ section.settings.subtitle_transform }};
    margin-bottom: {{ section.settings.subtitle_margin_bottom }}px;
    line-height: {{ section.settings.subtitle_line_height }};
  }

  .vera-hero__title {
    display: block;
    font-size: var(--title-size-desktop);
    color: var(--title-color-desktop);
    letter-spacing: var(--title-letter-spacing);
    font-weight: var(--title-font-weight);
    text-transform: {{ section.settings.title_transform }};
    line-height: {{ section.settings.title_line_height }};
    margin: 0;
  }

  {% if section.settings.button_enabled %}
  .vera-hero__btn-wrap {
    margin-top: {{ section.settings.button_margin_top }}px;
    display: flex;
    justify-content: var(--content-justify);
    gap: 16px;
    flex-wrap: wrap;
  }

  .vera-hero__btn {
    display: inline-block;
    padding: {{ section.settings.button_padding_v }}px {{ section.settings.button_padding_h }}px;
    background-color: {{ section.settings.button_bg }};
    color: {{ section.settings.button_text_color }};
    border: 2px solid {{ section.settings.button_border_color }};
    border-radius: {{ section.settings.button_radius }}px;
    font-size: {{ section.settings.button_font_size }}px;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .vera-hero__btn:hover {
    background-color: {{ section.settings.button_bg_hover }};
    color: {{ section.settings.button_text_color_hover }};
    border-color: {{ section.settings.button_border_color_hover }};
    transform: translateY(-2px);
  }
  {% endif %}

  /* ======= TABLET ======= */
  @media screen and (max-width: 1024px) and (min-width: 641px) {
    .vera-hero__section {
      height: var(--section-height-tablet);
    }
    .vera-hero__subtitle {
      font-size: var(--subtitle-size-tablet);
      color: var(--subtitle-color-tablet);
    }
    .vera-hero__title {
      font-size: var(--title-size-tablet);
      color: var(--title-color-tablet);
    }
    .vera-hero__content {
      {% if section.settings.content_alignment == 'right' %}
        margin-right: 40px;
      {% elsif section.settings.content_alignment == 'left' %}
        margin-left: 40px;
      {% endif %}
    }
  }

  /* ======= MOBILE ======= */
  @media screen and (max-width: 640px) {
    .vera-hero__section {
      height: var(--section-height-mobile);
      justify-content: center;
    }
    .vera-hero__subtitle {
      font-size: var(--subtitle-size-mobile);
      color: var(--subtitle-color-mobile);
    }
    .vera-hero__title {
      font-size: var(--title-size-mobile);
      color: var(--title-color-mobile);
    }
    .vera-hero__content {
      margin: 0 16px;
      text-align: center;
      {% if section.settings.content_bg_enabled %}
        padding: {{ section.settings.content_padding_v | divided_by: 1.3 | round }}px {{ section.settings.content_padding_h | divided_by: 1.3 | round }}px;
      {% else %}
        padding: 16px;
      {% endif %}
    }
    {% if section.settings.button_enabled %}
    .vera-hero__btn-wrap {
      justify-content: center;
    }
    {% endif %}
  }
</style>

<section 
  id="vera-hero-{{ section.id }}" 
  class="vera-hero__section"
  {% if section.settings.section_id != blank %}id="{{ section.settings.section_id }}"{% endif %}
>

  {% if section.settings.bg_image != blank %}
    <img
      class="vera-hero__bg"
      src="{{ section.settings.bg_image | img_url: 'master' }}"
      srcset="
        {{ section.settings.bg_image | img_url: '600x' }} 600w,
        {{ section.settings.bg_image | img_url: '1024x' }} 1024w,
        {{ section.settings.bg_image | img_url: '1440x' }} 1440w,
        {{ section.settings.bg_image | img_url: 'master' }} 1920w
      "
      sizes="100vw"
      alt="{{ section.settings.bg_image.alt | default: section.settings.title | escape }}"
      loading="{{ section.settings.image_loading }}"
    >
  {% else %}
    <div class="vera-hero__bg" style="background: {{ section.settings.fallback_bg_color }};"></div>
  {% endif %}

  {% if section.settings.overlay_opacity > 0 %}
    <div class="vera-hero__overlay"></div>
  {% endif %}

  <div class="vera-hero__content">

    {% if section.settings.subtitle != blank %}
      <span class="vera-hero__subtitle">{{ section.settings.subtitle }}</span>
    {% endif %}

    {% if section.settings.title != blank %}
      <{{ section.settings.title_tag }} class="vera-hero__title">{{ section.settings.title }}</{{ section.settings.title_tag }}>
    {% endif %}

    {% if section.settings.button_enabled and section.settings.button_label != blank %}
      <div class="vera-hero__btn-wrap">
        <a 
          href="{{ section.settings.button_link }}" 
          class="vera-hero__btn"
          {% if section.settings.button_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}
        >
          {{ section.settings.button_label }}
        </a>
        {% if section.settings.button2_enabled and section.settings.button2_label != blank %}
          <a 
            href="{{ section.settings.button2_link }}" 
            class="vera-hero__btn"
            style="background-color: transparent; color: {{ section.settings.button_border_color }}; border-color: {{ section.settings.button_border_color }};"
            {% if section.settings.button2_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}
          >
            {{ section.settings.button2_label }}
          </a>
        {% endif %}
      </div>
    {% endif %}

  </div>
</section>

{% schema %}
