          "default": "<p>Have a question, an idea, or just want to say hi? We’re always happy to hear from curious minds, thoughtful sippers, and anyone interested in a smarter way to drink.</p>"
        },
        {
          "type": "color",
          "id": "content_color",
          "label": "Content Color",
          "default": "#464646"
        },
        {
          "type": "color",
          "id": "content_bold_color",
          "label": "Content Bold Text Color",
          "default": "#8a2d73"
        },
        {
          "type": "color",
          "id": "content_link_color",
          "label": "Content Link Text Color",
          "default": "#8a2d73"
        },
        {
          "type": "range",
          "id": "content_font_size_desktop",
          "label": "Content Font Size - Desktop",
          "min": 10,
          "max": 40,
          "step": 1,
          "unit": "px",
          "default": 16
        },
        {
          "type": "range",
          "id": "content_font_size_tablet",
          "label": "Content Font Size - Tablet",
          "min": 10,
          "max": 32,
          "step": 1,
          "unit": "px",
          "default": 15
        },
        {
          "type": "range",
          "id": "content_font_size_mobile",
          "label": "Content Font Size - Mobile",
          "min": 10,
          "max": 28,
          "step": 1,
          "unit": "px",
          "default": 14
        } 
    ],
    "blocks": [
      {
        "type": "@app"
      },
    ],
    "presets": [
      {
        "name": "Contact Form Section",
      }
    ]
  }
{% endschema %}