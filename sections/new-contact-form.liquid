{%  style %}

.contact_section .contact_block{display: flex;flex-wrap: wrap;gap: 50px;}

.contact_section .contact_content_block{width: calc(50% - 25px);}

.contact_section .contact_title{color: {{ section.settings.title_color }};font-size: {{ section.settings.title_font_size_desktop }}px;margin-bottom: 40px;}

.contact_section .contact_content p{color: {{ section.settings.content_color }};font-size: {{ section.settings.content_font_size_desktop }}px;max-width: 420px;margin-bottom: 30px;}

.contact_section .contact_content p:nth-child(2){margin-top: 0;margin-bottom: 10px;line-height: normal;}
.contact_section .contact_content p:last-child{margin-top: 0;margin-bottom:0;line-height: normal;}

.contact_section .contact_content p strong{color: {{ section.settings.content_bold_color }};font-weight: 600;}

.contact_section .contact_content p a{text-decoration: none;color: {{ section.settings.content_link_color }};}
.contact_section .contact_content p a strong{font-weight: 400;color: {{ section.settings.content_link_color }};}

.contact_section .contact_form_block{width: calc(50% - 25px);}

.contact_section .pxFormGenerator .formContainer #formGeneratorForm .form_generater_form_div *{font-family: var(--din)!important;color: #8c8c8c !important;}

.contact_section .pxFormGenerator .formContainer #formGeneratorForm .form_generater_form_div,
.contact_section .pxFormGenerator .formContainer #formGeneratorForm .form_generater_form_div .col-md-12{padding: 0 !important;}

.contact_section .pxFormGenerator .formContainer #formGeneratorForm .form_generater_form_div .row{margin: 0!important}

.contact_section .hulk_form_4i1KScmSUYSKYrQVXpGqLw .form_generater_form_div {background: unset !important;max-width: 600px !important;width: 100% !important;padding: 35px !important;border: none !important;border-radius: 2px !important;margin: 0 auto !important;}

.contact_section .hulk_form_4i1KScmSUYSKYrQVXpGqLw .block_label {display: none !important;font-weight: var(--rift);}

.contact_section .hulk_form_4i1KScmSUYSKYrQVXpGqLw .form-group {padding: 0 !important;margin: 0 0 10px 0 !important;}

.contact_section .hulk_form_4i1KScmSUYSKYrQVXpGqLw .form-group textarea::placeholder,
.contact_section .hulk_form_4i1KScmSUYSKYrQVXpGqLw input.form-control::placeholder{color:  #8c8c8c !important;}

.contact_section .hulk_form_4i1KScmSUYSKYrQVXpGqLw input.form-control,
.contact_section .hulk_form_4i1KScmSUYSKYrQVXpGqLw textarea.form-control {background: #ffffff !important;border: 1px solid #ebe9e9 !important;border-radius: 1px !important;color:  #8c8c8c !important;font-family: var(--din)!important;font-size: 14px !important;padding: 10px 12px !important;width: 100% !important;display: block !important;transition: border-color 0.2s ease, background 0.2s ease !important;}

.contact_section .hulk_form_4i1KScmSUYSKYrQVXpGqLw input.form-control:focus,
.contact_section .hulk_form_4i1KScmSUYSKYrQVXpGqLw textarea.form-control:focus {border-color: #2d2727 !important;outline: none !important;}

.contact_section .hulk_form_4i1KScmSUYSKYrQVXpGqLw textarea.form-control {height: 160px !important;resize: none !important;}

.contact_section .pxFormGenerator .formContainer #formGeneratorForm .form_generater_form_div select{background-image: unset!important;text-align: center!important;}

.contact_section .hulk_form_4i1KScmSUYSKYrQVXpGqLw select.form-control {border: 1px solid #ebe9e9 !important;font-size: 13px !important;padding: 8px 12px !important;appearance: none !important;-webkit-appearance: none !important;cursor: pointer !important;transition: border-color 0.2s ease, background-color 0.2s ease !important;}

.contact_section .hulk_form_4i1KScmSUYSKYrQVXpGqLw select.form-control:focus {border-color: #2d2727 !important;outline: none !important;}

.contact_section .hulk_form_4i1KScmSUYSKYrQVXpGqLw .formElement_4 .row:before,
.contact_section .hulk_form_4i1KScmSUYSKYrQVXpGqLw .formElement_5 .row:before,
.contact_section .hulk_form_4i1KScmSUYSKYrQVXpGqLw .formElement_4:before,
.contact_section .hulk_form_4i1KScmSUYSKYrQVXpGqLw .formElement_5:before,
.contact_section .hulk_form_4i1KScmSUYSKYrQVXpGqLw .formElement_4:after,
.contact_section .hulk_form_4i1KScmSUYSKYrQVXpGqLw .formElement_5:after{content: unset!important;}

.contact_section .hulk_form_4i1KScmSUYSKYrQVXpGqLw .formElement_4 .form-group,
.contact_section .hulk_form_4i1KScmSUYSKYrQVXpGqLw .formElement_5 .form-group{display: flex;align-items: center;justify-content: space-between;width: 100%;}

.contact_section .hulk_form_4i1KScmSUYSKYrQVXpGqLw .formElement_4,
.contact_section .hulk_form_4i1KScmSUYSKYrQVXpGqLw .formElement_5 {display: flex !important;align-items: center !important;justify-content: space-between !important;gap: 12px !important;flex-wrap: nowrap !important;}

.contact_section .hulk_form_4i1KScmSUYSKYrQVXpGqLw .formElement_4 .block_label,
.contact_section .hulk_form_4i1KScmSUYSKYrQVXpGqLw .formElement_5 .block_label{display: block!important;margin: 0!important;color:  #8c8c8c !important;}

.contact_section .hulk_form_4i1KScmSUYSKYrQVXpGqLw .formElement_4 .row,
.contact_section .hulk_form_4i1KScmSUYSKYrQVXpGqLw .formElement_5 .row {width: 100% !important;margin: 0 !important;flex-shrink: 0 !important;}

.contact_section .hulk_form_4i1KScmSUYSKYrQVXpGqLw .formElement_4 select,
.contact_section .hulk_form_4i1KScmSUYSKYrQVXpGqLw .formElement_5 select {width: 185px !important;min-width: 185px !important;}

.contact_section .hulk_form_4i1KScmSUYSKYrQVXpGqLw .formElement_4 .col-sm-12,
.contact_section .hulk_form_4i1KScmSUYSKYrQVXpGqLw .formElement_5 .col-sm-12 {padding: 0 !important;margin: 0 !important;}

.contact_section .hulk_form_4i1KScmSUYSKYrQVXpGqLw .form_submit_div {text-align: left !important;margin-top: 16px !important;display: flex !important;align-items: center !important;justify-content: space-between !important;flex-wrap: wrap !important;gap: 10px !important;}

.contact_section .pxFormGenerator .formContainer #formGeneratorForm .form_generater_form_div .btn{background: #d11a74 !important;color: #fff!important;border: 1px solid  #d11a74!important;border-radius: 0 !important;padding: 8px 28px !important;font-size: 18px !important;font-weight: 500 !important;letter-spacing: 1px !important;text-transform: uppercase !important;cursor: pointer !important;width: auto !important;transition: background 0.2s ease !important;}

.contact_section .pxFormGenerator .formContainer #formGeneratorForm .form_generater_form_div .btn:hover {background: #000 !important;color: #fff!important;border: 1px solid  #000!important;}

.contact_section .hulk_form_4i1KScmSUYSKYrQVXpGqLw .alert-success {color: #d11a74 !important;background: transparent !important;border: none !important;font-size: 13px !important;font-weight: 700 !important;letter-spacing: 1px !important;text-transform: uppercase !important;font-family: 'Times New Roman', Times, serif !important;padding: 0 !important;}

.contact_section .hulk_form_4i1KScmSUYSKYrQVXpGqLw .alert_message {padding: 0 !important;margin: 0 !important;}


@media (max-width: 991px){

  .contact_section .contact_block{gap: 30px;}

  .contact_section .contact_content_block,
  .contact_section .contact_form_block{width: 100%;max-width: 600px;margin: 0 auto;}
  
}

@media (max-width: 767px){

  .contact_section .contact_title{font-size: {{ section.settings.title_font_size_tablet }}px;margin-bottom: 30px;}
  .contact_section .contact_content p{font-size: {{ section.settings.content_font_size_tablet }}px;margin-bottom: 20px;}

  .contact_section .pxFormGenerator .formContainer #formGeneratorForm .form_generater_form_div .btn{font-size: 16px !important;}

}


@media (max-width: 575px) {

  .contact_section .contact_title{font-size: {{ section.settings.title_font_size_mobile }}px;margin-bottom: 25px;}
  .contact_section .contact_content p{font-size: {{ section.settings.content_font_size_mobile }}px;margin-bottom: 15px;}

  .contact_section .hulk_form_4i1KScmSUYSKYrQVXpGqLw .form_generater_form_div {padding: 20px !important;}

  .contact_section .hulk_form_4i1KScmSUYSKYrQVXpGqLw .formElement_4,
  .contact_section .hulk_form_4i1KScmSUYSKYrQVXpGqLw .formElement_5 {flex-direction: column !important;align-items: flex-start !important;}

  .contact_section .hulk_form_4i1KScmSUYSKYrQVXpGqLw .formElement_4 select,
  .contact_section .hulk_form_4i1KScmSUYSKYrQVXpGqLw .formElement_5 select {width: 100% !important;min-width: unset !important;}

  .contact_section .hulk_form_4i1KScmSUYSKYrQVXpGqLw .form_submit_div {flex-direction: column !important;align-items: flex-start !important;}

  .contact_section .pxFormGenerator .formContainer #formGeneratorForm .form_generater_form_div .btn{font-size: 14px !important;}

  .contact_section .hulk_form_4i1KScmSUYSKYrQVXpGqLw .formElement_4 .form-group,
  .contact_section .hulk_form_4i1KScmSUYSKYrQVXpGqLw .formElement_5 .form-group{flex-direction: column;justify-content: flex-start;align-items: flex-start;}

  .contact_section .pxFormGenerator .formContainer #formGeneratorForm .form_generater_form_div select{width: 100%!important;max-width: 140px!important;text-align: left!important;}

}
 
{% endstyle %}


<section class="contact_section">

    <div class="section section--{{ section.settings.section_width }} section-resource-list spacing-style" style="{% render 'spacing-style', settings: section.settings %}">
    
        <div class="contact_block">
           <div class="contact_content_block">
            {% if section.settings.title != blank %}
              <h2 class="contact_title">{{ section.settings.title }}</h2>
            {% endif %}
            {% if section.settings.content != blank %}
              <div class="contact_content">
                {{ section.settings.content }}
              </div>
            {% endif %}

           </div>
           <div class="contact_form_block">
               {% content_for 'blocks' %}
           </div>
        </div>

    </div>

</section>

<script>
document.addEventListener('DOMContentLoaded', function () {
  const formInterval = setInterval(function () {
  const select4 = document.querySelector('.contact_form_block .formElement_4 select');
  const select5 = document.querySelector('.contact_form_block .formElement_5 select');

  if (select4 && select4.options.length > 0) {
    select4.options[0].text = 'Pick One';
  }

  if (select5 && select5.options.length > 0) {
    select5.options[0].text = 'Pick One';
  }

}, 300); // dar 300ms e check karse jyare su dhie milse band thai jase
});
</script>



{% schema %}
  {
    "name": "Contact Form Section",
    "settings": [
        {
          "type": "header",
          "content": "t:content.padding"
        },
        {
          "type": "range",
          "id": "padding-block-start",
          "label": "t:settings.top",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "px",
          "default": 0
        },
        {
          "type": "range",
          "id": "padding-block-end",
          "label": "t:settings.bottom",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "px",
          "default": 0
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "CLARITY STARTS WITH A CONVERSTATION."
        },
         {
          "type": "color",
          "id": "title_color",
          "label": "Title Color",
          "default": "#000000"
        },
        {
          "type": "range",
          "id": "title_font_size_desktop",
          "label": "Title Font Size - Desktop",
          "min": 12,
          "max": 80,
          "step": 1,
          "unit": "px",
          "default": 32
        },
        {
          "type": "range",
          "id": "title_font_size_tablet",
          "label": "Title Font Size - Tablet",
          "min": 12,
          "max": 60,
          "step": 1,
          "unit": "px",
          "default": 26
        },
        {
          "type": "range",
          "id": "title_font_size_mobile",
          "label": "Title Font Size - Mobile",
          "min": 12,
          "max": 48,
          "step": 1,
          "unit": "px",
          "default": 22
        },
        {
          "type": "richtext",
          "id": "content",
