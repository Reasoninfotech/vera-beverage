{% comment %}
  Section: Body & Mind Perform
  Pixel-perfect recreation of the "Made to Support How Your Body and Mind Perform" section
{% endcomment %}

<section class="body-mind-section" style=" background-color: {{ section.settings.background_color }};">
  <div class="body-mind-section__container">
    <div class="body-mind-section__content">
      <h2
        class="body-mind-section__heading"
        style="
          color: {{ section.settings.heading_color }};
          text-transform: {{ section.settings.heading_text_transform }};
          line-height: {{ section.settings.heading_line_height }};
          font-weight: {{ section.settings.heading_font_weight }};
          margin-bottom: {{ section.settings.heading_bottom_margin }}px;
        "
      >
        {{ section.settings.heading }}
      </h2>

      <p
        class="body-mind-section__body"
        style="
          color: {{ section.settings.body_text_color }};
          line-height: {{ section.settings.body_line_height }};
          margin-bottom: {{ section.settings.body_bottom_margin }}px;
          max-width: {{ section.settings.text_max_width }}px;
        "
      >
        {{ section.settings.body_text }}
      </p>

      {% if section.settings.cta_text != blank %}
        <p
          class="body-mind-section__cta-text"
          style="
            color: {{ section.settings.cta_text_color }};
            line-height: {{ section.settings.body_line_height }};
            font-weight: {{ section.settings.cta_text_font_weight }};
            max-width: {{ section.settings.text_max_width }}px;
          "
        >
          {{ section.settings.cta_text }}
        </p>
      {% endif %}
    </div>

    <div class="body-mind-section__image-wrapper" style=" width: {{ section.settings.image_width }}px; height: {{ section.settings.image_height }}px;">
      {% if section.settings.image != blank %}
        <img
          src="{{ section.settings.image | image_url: width: 800 }}"
          alt="{{ section.settings.image.alt | escape | default: section.settings.heading }}"
          width="{{ section.settings.image_width }}"
          height="{{ section.settings.image_height }}"
          loading="{{ section.settings.image_loading }}"
          class="body-mind-section__image"
        >
      {% else %}
        {{ 'lifestyle-1' | placeholder_svg_tag: 'body-mind-section__image body-mind-section__image--placeholder' }}
      {% endif %}
    </div>
  </div>
</section>

<style>
  .body-mind-section {
    width: 100%;
    padding: {{ section.settings.section_padding_vertical }}px 0;
    box-sizing: border-box;
  }

  .body-mind-section__container {
    max-width: {{ section.settings.container_max_width }}px;
    margin: 0 auto;
    padding: 0 {{ section.settings.container_padding_horizontal }}px;
    display: flex;
    align-items: center;
    gap: {{ section.settings.content_gap }}px;
    flex-direction: {% if section.settings.image_position == 'right' %}row{% else %}row-reverse{% endif %};
  }

  .body-mind-section__content {
    flex: 1;
    min-width: 0;
  }

  .body-mind-section__heading {
    font-size: {{ section.settings.heading_font_size }}px;
    margin: 0 0 {{ section.settings.heading_bottom_margin }}px;
    padding: 0;
  }

  .body-mind-section__body {
    font-size: {{ section.settings.body_font_size }}px;
    margin: 0 0 {{ section.settings.body_bottom_margin }}px;
    padding: 0;
  }

  .body-mind-section__cta-text {
    font-size: {{ section.settings.cta_text_font_size }}px;
    margin: 0;
    padding: 0;
  }

  .body-mind-section__image-wrapper {
    flex-shrink: 0;
    overflow: hidden;
    border-radius: {{ section.settings.image_border_radius }}px;

  }

  .body-mind-section__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .body-mind-section__image--placeholder {
    width: 100%;
    height: 100%;
    background-color: #e0e0e0;
  }

  @media screen and (max-width: 1024px) {
    .body-mind-section__container {
      gap: 40px;
    }

    .body-mind-section__image-wrapper {
      width: 380px !important;
      height: 450px !important;
    }
  }

  @media screen and (max-width: 768px) {

    .body-mind-section {
      padding: {{ section.settings.section_padding_vertical_tablet }}px 0;
    }

    .body-mind-section__container {
      padding: 0 {{ section.settings.container_padding_horizontal_mobile }}px;
      flex-direction: column !important;
      gap: 32px;
    }

    .body-mind-section__image-wrapper {
      width: 100% !important;
      max-width: 100%;
    }

    .body-mind-section__heading {
      font-size: {{ section.settings.heading_font_size_tablet }}px;
    }

    .body-mind-section__body{
      font-size: {{ section.settings.body_font_size_tablet }}px;
    }

    .body-mind-section__body,
    .body-mind-section__cta-text {
      max-width: 100% !important;
    }

    .body-mind-section__cta-text{
     font-size: {{ section.settings.cta_text_font_size_tablet }}px;
    }
    
  }

  @media (max-width: 575px){

    .body-mind-section {
      padding: {{ section.settings.section_padding_vertical_mobile }}px 0;
    }

    .body-mind-section__heading {
      font-size: {{ section.settings.heading_font_size_mobile }}px;
    }

    .body-mind-section__body{
      font-size: {{ section.settings.body_font_size_mobile }}px;
    }

    .body-mind-section__cta-text{
      font-size: {{ section.settings.cta_text_font_size_mobile }}px;
    }
  
  }

</style>

