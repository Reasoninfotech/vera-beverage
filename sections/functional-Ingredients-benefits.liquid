{% comment %}
  Functional Ingredients & Benefits Section
  Theme: Horizon
  Version: 1.0.0
{% endcomment %}

<style>
  .fib-section {
    background-color: {{ section.settings.bg_color }};
    padding: {{ section.settings.section_padding_mobile }}px 15px;
  }

  .fib-section .fib-container {
    max-width: 1120px;
    margin: 0 auto;
  }

  /* ── Title ── */
  .fib-section .fib-title {
    text-align: center;
    color: {{ section.settings.title_color }};
    font-size: {{ section.settings.title_font_size_mobile }}px;
    font-weight: {{ section.settings.title_font_weight }};
    text-transform: uppercase;
    margin-bottom: 40px;
  }

  /* ── Icon Blocks Row ── */
  .fib-icons-row {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 24px 2px;
    margin-bottom: 48px;
  }

  .fib-icon-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    min-width: 90px;
  }

  .fib-icon-wrap {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    background-color: {{ section.settings.icon_circle_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .fib-icon-wrap svg {
    width: 68px;
    height: 68px;
    fill: none;
    stroke: {{ section.settings.icon_svg_color }};
    stroke-width: 1.5;
  }

  .fib-icon-wrap img {
    width: 68px;
    height: 68px;
    object-fit: contain;
  }

  .fib-icon-label {
    color: {{ section.settings.icon_text_color }};
    font-size: {{ section.settings.icon_text_size_mobile }}px;
    font-weight: 500;
    text-transform: uppercase;
    text-align: center;
  }

  /* ── Card Grid ── */
  .fib-cards-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }

  .fib-card {
    background-color: {{ section.settings.card_bg_color }};
    border-radius: {{ section.settings.card_border_radius }}px;
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(0,0,0,0.07);
  }

  .fib-card__image {
    width: 100%;
    height: {{ section.settings.card_image_height_mobile }}px;
    object-fit: cover;
    display: block;
  }

  .fib-card__body {
    padding: 20px;
  }

  .fib-card__title {
    color: {{ section.settings.card_title_color }};
    font-weight: 500;
    text-transform: uppercase;
    margin-bottom: 12px;
  }

  .fib-card__points ul{
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .fib-card__points li {
    color: {{ section.settings.card_subpoint_color }};
    font-size: {{ section.settings.card_subpoint_size_mobile }}px;
    display: flex;
    align-items: flex-start;
    gap: 6px;
    line-height: 1.5;
  }

  .fib-card__points li::before {
    content: '·';
    font-size: 18px;
    line-height: 1.2;
    flex-shrink: 0;
    color: {{ section.settings.card_bullet_color }};
  }

   #fib-{{ section.id }} .fib-card__title {
      font-size: {{ section.settings.card_title_size_mobile }}px !important;
    }



  /* ── Tablet 768px ── */
  @media (min-width: 768px) {
    .fib-section {
      padding: {{ section.settings.section_padding_tablet }}px 30px;
    }

    .fib-section .fib-title {
      font-size: {{ section.settings.title_font_size_tablet }}px;
    }

    .fib-icon-label {
      font-size: {{ section.settings.icon_text_size_tablet }}px;
    }

    .fib-cards-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    #fib-{{ section.id }} .fib-card__title {
        font-size: {{ section.settings.card_title_size_tablet }}px !important;
    }
    #fib-{{ section.id }} .fib-card__points li {
        font-size: {{ section.settings.card_subpoint_size_tablet }}px !important;
    }
    #fib-{{ section.id }} .fib-card__image {
        height: {{ section.settings.card_image_height_tablet }}px !important;
    }


  }

  /* ── Desktop 1024px ── */
  @media (min-width: 1024px) {
    .fib-section {
      padding: {{ section.settings.section_padding_desktop }}px 15px;
    }

    .fib-section .fib-title {
      font-size: {{ section.settings.title_font_size_desktop }}px;
    }

    .fib-icon-label {
      font-size: {{ section.settings.icon_text_size_desktop }}px;
    }

    .fib-cards-grid {
      grid-template-columns: repeat(3, 1fr);
    }

    #fib-{{ section.id }} .fib-card__title {
        font-size: {{ section.settings.card_title_size_desktop }}px !important;
    }
    #fib-{{ section.id }} .fib-card__points li {
        font-size: {{ section.settings.card_subpoint_size_desktop }}px !important;
    }
    #fib-{{ section.id }} .fib-card__image {
        height: {{ section.settings.card_image_height_desktop }}px !important;
        width: {{ section.settings.card_image_width }}px !important;
        max-width: 100%;
    }


  }
</style>

<section class="fib-section" id="fib-{{ section.id }}">
  <div class="fib-container">

    {% if section.settings.title != blank %}
      <h2 class="fib-title">{{ section.settings.title }}</h2>
    {% endif %}

    {% comment %} ── Block Type: icon_row ── {% endcomment %}
    {% for block in section.blocks %}
      {% if block.type == 'icon_row' %}
        <div class="fib-icons-row" {{ block.shopify_attributes }}>

          {% comment %} Icon 1 {% endcomment %}
          {% if block.settings.icon1_text != blank %}
            <div class="fib-icon-item">
              <div class="fib-icon-wrap">
                {% if block.settings.icon1_svg != blank %}
                  {{ block.settings.icon1_svg }}
                {% elsif block.settings.icon1_image != blank %}
                  <img src="{{ block.settings.icon1_image | img_url: '80x80' }}" alt="{{ block.settings.icon1_text }}" width="38" height="38">
                {% else %}
                  <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/></svg>
                {% endif %}
              </div>
              <span class="fib-icon-label" style="font-size: {{ block.settings.icon_text_size_mobile }}px;">
                {{ block.settings.icon1_text }}
              </span>
            </div>
          {% endif %}

          {% comment %} Icon 2 {% endcomment %}
          {% if block.settings.icon2_text != blank %}
            <div class="fib-icon-item">
              <div class="fib-icon-wrap">
                {% if block.settings.icon2_svg != blank %}
                  {{ block.settings.icon2_svg }}
                {% elsif block.settings.icon2_image != blank %}
                  <img src="{{ block.settings.icon2_image | img_url: '80x80' }}" alt="{{ block.settings.icon2_text }}" width="38" height="38">
                {% else %}
                  <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/></svg>
                {% endif %}
              </div>
              <span class="fib-icon-label" style="font-size: {{ block.settings.icon_text_size_mobile }}px;">
                {{ block.settings.icon2_text }}
              </span>
            </div>
          {% endif %}

          {% comment %} Icon 3 {% endcomment %}
          {% if block.settings.icon3_text != blank %}
            <div class="fib-icon-item">
              <div class="fib-icon-wrap">
                {% if block.settings.icon3_svg != blank %}
                  {{ block.settings.icon3_svg }}
                {% elsif block.settings.icon3_image != blank %}
                  <img src="{{ block.settings.icon3_image | img_url: '80x80' }}" alt="{{ block.settings.icon3_text }}" width="38" height="38">
                {% else %}
                  <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/></svg>
                {% endif %}
              </div>
              <span class="fib-icon-label" style="font-size: {{ block.settings.icon_text_size_mobile }}px;">
                {{ block.settings.icon3_text }}
              </span>
            </div>
          {% endif %}

          {% comment %} Icon 4 {% endcomment %}
          {% if block.settings.icon4_text != blank %}
            <div class="fib-icon-item">
              <div class="fib-icon-wrap">
                {% if block.settings.icon4_svg != blank %}
                  {{ block.settings.icon4_svg }}
                {% elsif block.settings.icon4_image != blank %}
                  <img src="{{ block.settings.icon4_image | img_url: '80x80' }}" alt="{{ block.settings.icon4_text }}" width="38" height="38">
                {% else %}
                  <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/></svg>
                {% endif %}
              </div>
              <span class="fib-icon-label" style="font-size: {{ block.settings.icon_text_size_mobile }}px;">
                {{ block.settings.icon4_text }}
              </span>
            </div>
          {% endif %}

        </div>
      {% endif %}
    {% endfor %}

    {% comment %} ── Block Type: ingredient_cards ── {% endcomment %}
    <div class="fib-cards-grid">
      {% for block in section.blocks %}

        {% if block.type == 'ingredient_cards' %}

          {% comment %} Card 1 {% endcomment %}
          {% if block.settings.card1_title != blank or block.settings.card1_image != blank %}
            <div class="fib-card" {{ block.shopify_attributes }}>
              {% if block.settings.card1_image != blank %}
                <img
                  class="fib-card__image"
                  src="{{ block.settings.card1_image | img_url: '600x400', crop: 'center' }}"
                  alt="{{ block.settings.card1_title }}"
                  width="{{ block.settings.card_image_width }}"
                  height="{{ block.settings.card_image_height_desktop }}"
                  loading="lazy"
                >
              {% endif %}
              <div class="fib-card__body">
                {% if block.settings.card1_title != blank %}
                  <h3 class="fib-card__title"
                    style="color:{{ block.settings.card_title_color }};">
                    {{ block.settings.card1_title }}
                  </h3>
                {% endif %}
                {% if block.settings.card1_point1 != blank %}
                <div class="fib-card__points">
                    {{ block.settings.card1_point1 }}
                </div>
                {% endif %} 
              </div>
            </div>
          {% endif %}

          {% comment %} Card 2 {% endcomment %}
          {% if block.settings.card2_title != blank or block.settings.card2_image != blank %}
            <div class="fib-card">
              {% if block.settings.card2_image != blank %}
                <img
                  class="fib-card__image"
                  src="{{ block.settings.card2_image | img_url: '600x400', crop: 'center' }}"
                  alt="{{ block.settings.card2_title }}"
                  loading="lazy"
                >
              {% endif %}
              <div class="fib-card__body">
                {% if block.settings.card2_title != blank %}
                  <h3 class="fib-card__title"
                    style="color:{{ block.settings.card_title_color }};">
                    {{ block.settings.card2_title }}
                  </h3>
                {% endif %}

                {% if block.settings.card2_point1 != blank %}
                <div class="fib-card__points">
                    {{ block.settings.card2_point1 }}
                </div>
                {% endif %}


              </div>
            </div>
          {% endif %}

          {% comment %} Card 3 {% endcomment %}
          {% if block.settings.card3_title != blank or block.settings.card3_image != blank %}
            <div class="fib-card">
              {% if block.settings.card3_image != blank %}
                <img
                  class="fib-card__image"
                  src="{{ block.settings.card3_image | img_url: '600x400', crop: 'center' }}"
                  alt="{{ block.settings.card3_title }}"
                  loading="lazy"
                >
              {% endif %}
              <div class="fib-card__body">
                {% if block.settings.card3_title != blank %}
                  <h3 class="fib-card__title"
                    style="color:{{ block.settings.card_title_color }};">
                    {{ block.settings.card3_title }}
                  </h3>
                {% endif %}
                {% if block.settings.card3_point1 != blank %}
                <div class="fib-card__points">
                    {{ block.settings.card3_point1 }}
                </div>
                {% endif %}
              </div>
            </div>
          {% endif %}

        {% endif %}
      {% endfor %}
    </div>

  </div>
</section>



