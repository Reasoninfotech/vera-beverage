      "default": "#7b2d6e"
    },
    {
      "type": "range",
      "id": "subtitle_font_size_desktop",
      "label": "Subtitle Font Size – Desktop (px)",
      "min": 10,
      "max": 40,
      "step": 1,
      "default": 18
    },
    {
      "type": "range",
      "id": "subtitle_font_size_mobile",
      "label": "Subtitle Font Size – Mobile (px)",
      "min": 10,
      "max": 30,
      "step": 1,
      "default": 14
    },
    {
      "type": "range",
      "id": "subtitle_letter_spacing",
      "label": "Subtitle Letter Spacing (em × 100)",
      "min": 0,
      "max": 30,
      "step": 1,
      "default": 12
    },
    {
