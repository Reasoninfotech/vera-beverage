{% comment %}
  ============================================================
  Section: Vera – "What You Won't Find" Features Section
  Theme:   Horizon (Shopify)
  Author:  Custom
  ============================================================
{% endcomment %}

{%- liquid
  assign section_id = 'vera-features-' | append: section.id
  assign bg_color   = section.settings.background_color
  assign overlay_op = section.settings.overlay_opacity | divided_by: 100.0
-%}

<style>
  /* ──────────────────────────────────────────────
     ROOT / CUSTOM PROPERTIES
  ────────────────────────────────────────────── */
  #{{ section_id }} {
    --vera-bg:              {{ bg_color }};
    --vera-overlay-op:      {{ overlay_op }};
    --vera-heading-color:   {{ section.settings.heading_color }};
    --vera-item-color:      {{ section.settings.item_color }};
    --vera-body-color:      {{ section.settings.body_color }};
    --vera-divider-color:   {{ section.settings.divider_color }};

    /* Desktop font sizes */
    --vera-heading-size-d:  {{ section.settings.heading_size_desktop }}px;
    --vera-item-size-d:     {{ section.settings.item_size_desktop }}px;
    --vera-body-size-d:     {{ section.settings.body_size_desktop }}px;

    /* Tablet font sizes */
    --vera-heading-size-t:  {{ section.settings.heading_size_tablet }}px;
    --vera-item-size-t:     {{ section.settings.item_size_tablet }}px;
    --vera-body-size-t:     {{ section.settings.body_size_tablet }}px;

    /* Mobile font sizes */
    --vera-heading-size-m:  {{ section.settings.heading_size_mobile }}px;
    --vera-item-size-m:     {{ section.settings.item_size_mobile }}px;
    --vera-body-size-m:     {{ section.settings.body_size_mobile }}px;

    /* Spacing */
    --vera-section-pt-d:    {{ section.settings.padding_top_desktop }}px;
    --vera-section-pb-d:    {{ section.settings.padding_bottom_desktop }}px;
    --vera-section-pt-t:    {{ section.settings.padding_top_tablet }}px;
    --vera-section-pb-t:    {{ section.settings.padding_bottom_tablet }}px;
    --vera-section-pt-m:    {{ section.settings.padding_top_mobile }}px;
    --vera-section-pb-m:    {{ section.settings.padding_bottom_mobile }}px;

    --vera-item-gap-d:      {{ section.settings.item_gap_desktop }}px;
    --vera-item-gap-t:      {{ section.settings.item_gap_tablet }}px;
    --vera-item-gap-m:      {{ section.settings.item_gap_mobile }}px;

    --vera-heading-ls:      {{ section.settings.heading_letter_spacing }}em;
    --vera-item-ls:         {{ section.settings.item_letter_spacing }}em;

    --vera-heading-weight:  {{ section.settings.heading_font_weight }};
    --vera-item-weight:     {{ section.settings.item_font_weight }};

    --vera-text-align:      {{ section.settings.text_alignment }};
    --vera-content-width:   {{ section.settings.content_max_width }}px;
  }

  /* ──────────────────────────────────────────────
     SECTION WRAPPER
  ────────────────────────────────────────────── */
  #{{ section_id }} {
    position:     relative;
    overflow:     hidden;
    display:      flex;
    align-items:  center;
    justify-content: center;
    min-height:   {{ section.settings.min_height_desktop }}px;
    padding-top:    var(--vera-section-pt-d);
    padding-bottom: var(--vera-section-pb-d);
    background-color: var(--vera-bg);
    isolation: isolate;
  }

  /* ──────────────────────────────────────────────
     BACKGROUND IMAGE / VIDEO
  ────────────────────────────────────────────── */
  #{{ section_id }} .vera__bg-media {
    position:   absolute;
    inset:      0;
    z-index:    0;
  }
  #{{ section_id }} .vera__bg-media img,
  #{{ section_id }} .vera__bg-media video {
    width:      100%;
    height:     100%;
    object-fit: {{ section.settings.bg_image_fit }};
    object-position: {{ section.settings.bg_image_position }};
    display:    block;
  }

  /* ──────────────────────────────────────────────
     COLOR OVERLAY
  ────────────────────────────────────────────── */
  #{{ section_id }} .vera__overlay {
    position: absolute;
    inset:    0;
    z-index:  1;
    background: {{ section.settings.overlay_color }};
    opacity:  var(--vera-overlay-op);
  }

  /* Gradient overlay toggle */
  {% if section.settings.enable_gradient_overlay %}
  #{{ section_id }} .vera__gradient {
    position: absolute;
    inset:    0;
    z-index:  2;
    background: {{ section.settings.gradient_css }};
    opacity:  {{ section.settings.gradient_opacity | divided_by: 100.0 }};
  }
  {% endif %}

  /* ──────────────────────────────────────────────
     INNER CONTENT CONTAINER
  ────────────────────────────────────────────── */
  #{{ section_id }} .vera__inner {
    position:    relative;
    z-index:     3;
    width:       100%;
    max-width:   var(--vera-content-width);
    margin:      0 auto;
    padding:     0 {{ section.settings.content_padding_x }}px;
    text-align:  var(--vera-text-align);
  }

  /* ──────────────────────────────────────────────
     EYEBROW / PRE-TITLE
  ────────────────────────────────────────────── */
  #{{ section_id }} .vera__eyebrow {
    display:        block;
    font-size:      {{ section.settings.eyebrow_size }}px;
    color:          {{ section.settings.eyebrow_color }};
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin-bottom:  14px;
    font-weight:    600;
  }

  /* ──────────────────────────────────────────────
     MAIN HEADING
  ────────────────────────────────────────────── */
  #{{ section_id }} .vera__heading {
    font-size:      var(--vera-heading-size-d);
    color:          var(--vera-heading-color);
    font-weight:    var(--vera-heading-weight);
    letter-spacing: var(--vera-heading-ls);
    text-transform: uppercase;
    line-height:    1.1;
    margin:         0 0 {{ section.settings.heading_margin_bottom }}px;
  }

  /* ──────────────────────────────────────────────
     DIVIDER (between heading and items)
  ────────────────────────────────────────────── */
  {% if section.settings.show_divider %}
  #{{ section_id }} .vera__divider {
    width:  {{ section.settings.divider_width }}px;
    height: {{ section.settings.divider_height }}px;
    background: var(--vera-divider-color);
    margin: {{ section.settings.divider_margin }}px auto;
    {% if section.settings.text_alignment == 'left' %}
    margin-left: 0;
    {% elsif section.settings.text_alignment == 'right' %}
    margin-right: 0;
    {% endif %}
    border-radius: {{ section.settings.divider_height | divided_by: 2 }}px;
  }
  {% endif %}

  /* ──────────────────────────────────────────────
     NO-ITEMS LIST
  ────────────────────────────────────────────── */
  #{{ section_id }} .vera__items {
    list-style: none;
    margin:     0;
    padding:    0;
    display:    flex;
    flex-direction: column;
    gap:        var(--vera-item-gap-d);
    margin-bottom: {{ section.settings.items_margin_bottom }}px;
  }

  #{{ section_id }} .vera__item {
    font-size:      var(--vera-item-size-d);
    color:          var(--vera-item-color);
    font-weight:    var(--vera-item-weight);
    letter-spacing: var(--vera-item-ls);
    text-transform: uppercase;
    line-height:    1.2;
    position:       relative;
    transition:     opacity 0.2s ease, transform 0.2s ease;
  }

  {% if section.settings.item_hover_effect %}
  #{{ section_id }} .vera__item:hover {
    opacity: 0.75;
    transform: translateX({{ section.settings.item_hover_shift }}px);
  }
  {% endif %}

  /* Item prefix icon / bullet */
  {% if section.settings.show_item_prefix %}
  #{{ section_id }} .vera__item::before {
    content: '{{ section.settings.item_prefix_char }}';
    margin-right: 8px;
    color: {{ section.settings.item_prefix_color }};
    font-size: 0.7em;
    vertical-align: middle;
  }
  {% endif %}

  /* ──────────────────────────────────────────────
     BODY / DESCRIPTION TEXT
  ────────────────────────────────────────────── */
  #{{ section_id }} .vera__body {
    font-size:      var(--vera-body-size-d);
    color:          var(--vera-body-color);
    line-height:    1.65;
    max-width:      {{ section.settings.body_max_width }}px;
    margin:         0 auto;
    {% if section.settings.text_alignment == 'left' %}
    margin-left: 0;
    {% elsif section.settings.text_alignment == 'right' %}
    margin-right: 0;
    {% endif %}
  }

  /* ──────────────────────────────────────────────
     CTA BUTTON
  ────────────────────────────────────────────── */
  {% if section.settings.show_button %}
  #{{ section_id }} .vera__cta-wrap {
    margin-top: {{ section.settings.button_margin_top }}px;
  }
  #{{ section_id }} .vera__btn {
    display:         inline-block;
    padding:         {{ section.settings.button_padding_y }}px {{ section.settings.button_padding_x }}px;
    font-size:       {{ section.settings.button_font_size }}px;
    font-weight:     700;
    letter-spacing:  0.1em;
    text-transform:  uppercase;
    text-decoration: none;
    border-radius:   {{ section.settings.button_border_radius }}px;
    border:          {{ section.settings.button_border_width }}px solid {{ section.settings.button_border_color }};
    color:           {{ section.settings.button_text_color }};
    background:      {{ section.settings.button_bg_color }};
    transition:      background 0.25s ease, color 0.25s ease, border-color 0.25s ease, transform 0.2s ease;
    cursor:          pointer;
  }
  #{{ section_id }} .vera__btn:hover {
    background:    {{ section.settings.button_hover_bg }};
    color:         {{ section.settings.button_hover_text }};
    border-color:  {{ section.settings.button_hover_border }};
    transform:     translateY(-2px);
  }
  {% endif %}

  /* ──────────────────────────────────────────────
     FADE-IN ANIMATION
  ────────────────────────────────────────────── */
  {% if section.settings.enable_animation %}
  #{{ section_id }} .vera__eyebrow,
  #{{ section_id }} .vera__heading,
  #{{ section_id }} .vera__divider,
  #{{ section_id }} .vera__item,
  #{{ section_id }} .vera__body,
  #{{ section_id }} .vera__btn {
    opacity:   0;
    transform: translateY(22px);
    animation: veraFadeUp 0.65s ease forwards;
  }
  #{{ section_id }} .vera__eyebrow  { animation-delay: 0.05s; }
  #{{ section_id }} .vera__heading  { animation-delay: 0.15s; }
  #{{ section_id }} .vera__divider  { animation-delay: 0.25s; }

  {% for block in section.blocks %}
    {% if block.type == 'no_item' %}
    #{{ section_id }} .vera__item:nth-child({{ forloop.index }}) {
      animation-delay: {{ 0.25 | plus: forloop.index | times: 0.1 }}s;
    }
    {% endif %}
  {% endfor %}

  #{{ section_id }} .vera__body { animation-delay: 0.75s; }
  #{{ section_id }} .vera__btn  { animation-delay: 0.85s; }

  @keyframes veraFadeUp {
    to { opacity: 1; transform: translateY(0); }
  }
  {% endif %}

  /* ──────────────────────────────────────────────
     TABLET  ≤ 1024px
  ────────────────────────────────────────────── */
  @media screen and (max-width: 1024px) {
    #{{ section_id }} {
      min-height:     {{ section.settings.min_height_tablet }}px;
      padding-top:    var(--vera-section-pt-t);
      padding-bottom: var(--vera-section-pb-t);
    }
    #{{ section_id }} .vera__heading {
      font-size: var(--vera-heading-size-t);
    }
    #{{ section_id }} .vera__item {
      font-size: var(--vera-item-size-t);
    }
    #{{ section_id }} .vera__body {
      font-size: var(--vera-body-size-t);
    }
    #{{ section_id }} .vera__items {
      gap: var(--vera-item-gap-t);
    }
  }

  /* ──────────────────────────────────────────────
     MOBILE  ≤ 767px
  ────────────────────────────────────────────── */
  @media screen and (max-width: 767px) {
    #{{ section_id }} {
      min-height:     {{ section.settings.min_height_mobile }}px;
      padding-top:    var(--vera-section-pt-m);
      padding-bottom: var(--vera-section-pb-m);
    }
    #{{ section_id }} .vera__heading {
      font-size: var(--vera-heading-size-m);
    }
    #{{ section_id }} .vera__item {
      font-size: var(--vera-item-size-m);
    }
    #{{ section_id }} .vera__body {
      font-size: var(--vera-body-size-m);
    }
    #{{ section_id }} .vera__items {
      gap: var(--vera-item-gap-m);
    }
    #{{ section_id }} .vera__inner {
      padding: 0 {{ section.settings.content_padding_x_mobile }}px;
    }
  }
</style>

<!-- ═══════════════════════════════════════════
     SECTION HTML
══════════════════════════════════════════════ -->
<section
  id="{{ section_id }}"
  class="vera-features-section"
  aria-label="{{ section.settings.heading | escape }}"
>

  {%- comment %} ── Background Media ── {%- endcomment %}
  <div class="vera__bg-media" aria-hidden="true">
    {%- if section.settings.background_video != blank -%}
      <video
        src="{{ section.settings.background_video }}"
        autoplay
        muted
        loop
        playsinline
        aria-hidden="true"
      ></video>
    {%- elsif section.settings.background_image != blank -%}
      {{
        section.settings.background_image
          | image_url: width: 2000
          | image_tag:
            loading: 'lazy',
            widths: '600, 900, 1200, 1600, 2000',
            sizes: '100vw',
            alt: ''
      }}
    {%- endif -%}
  </div>

  {%- comment %} ── Color Overlay ── {%- endcomment %}
  <div class="vera__overlay" aria-hidden="true"></div>

  {%- comment %} ── Gradient Overlay ── {%- endcomment %}
  {% if section.settings.enable_gradient_overlay %}
    <div class="vera__gradient" aria-hidden="true"></div>
  {% endif %}

  {%- comment %} ── Content ── {%- endcomment %}
  <div class="vera__inner">

    {%- if section.settings.eyebrow != blank -%}
      <span class="vera__eyebrow">{{ section.settings.eyebrow | escape }}</span>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <{{ section.settings.heading_tag }} class="vera__heading">
        {{ section.settings.heading | escape }}
      </{{ section.settings.heading_tag }}>
    {%- endif -%}

    {%- if section.settings.show_divider -%}
      <div class="vera__divider" aria-hidden="true"></div>
    {%- endif -%}

    {%- comment %} ── "No …" Items from Blocks ── {%- endcomment %}
    {%- assign no_items = section.blocks | where: 'type', 'no_item' -%}
    {%- if no_items.size > 0 -%}
      <ul class="vera__items" role="list">
        {%- for block in no_items -%}
          {%- if block.settings.item_text != blank -%}
            <li class="vera__item" {{ block.shopify_attributes }}>
              {{ block.settings.item_text | escape }}
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    {%- endif -%}

    {%- comment %} ── Body Text ── {%- endcomment %}
    {%- if section.settings.body_text != blank -%}
      <div class="vera__body">{{ section.settings.body_text }}</div>
    {%- endif -%}

    {%- comment %} ── CTA Button ── {%- endcomment %}
    {%- if section.settings.show_button and section.settings.button_label != blank -%}
      <div class="vera__cta-wrap">
        <a
          href="{{ section.settings.button_url }}"
          class="vera__btn"
          {% if section.settings.button_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}
        >
          {{ section.settings.button_label | escape }}
        </a>
      </div>
    {%- endif -%}

  </div><!-- /.vera__inner -->
</section><!-- /.vera-features-section -->


<!-- ═══════════════════════════════════════════
     SCHEMA
══════════════════════════════════════════════ -->
{% schema %}
{
  "name": "Vera What You Won't Find",
  "tag": "section",
  "class": "vera-features-section-wrapper",
  "settings": [

    {
      "type": "header",
      "content": "🖼️ Background"
    },
    {
      "type":  "image_picker",
      "id":    "background_image",
      "label": "Background Image"
    },
    {
      "type":  "text",
      "id":    "background_video",
      "label": "Background Video URL",
      "info":  "Enter a direct .mp4 URL (overrides image if set)"
    },
    {
      "type":    "select",
      "id":      "bg_image_fit",
      "label":   "Image Fit",
      "options": [
        { "value": "cover",   "label": "Cover"   },
        { "value": "contain", "label": "Contain" },
        { "value": "fill",    "label": "Fill"    }
      ],
      "default": "cover"
    },
    {
      "type":    "select",
      "id":      "bg_image_position",
      "label":   "Image Position",
      "options": [
        { "value": "center center", "label": "Center Center" },
        { "value": "top center",    "label": "Top Center"    },
        { "value": "bottom center", "label": "Bottom Center" },
        { "value": "left center",   "label": "Left Center"   },
        { "value": "right center",  "label": "Right Center"  }
      ],
      "default": "center center"
    },
    {
      "type":    "color",
      "id":      "background_color",
      "label":   "Fallback Background Color",
      "default": "#6a0572"
    },

    {
      "type": "header",
      "content": "🎨 Overlay"
    },
    {
      "type":    "color",
      "id":      "overlay_color",
      "label":   "Overlay Color",
      "default": "#8B1A8B"
    },
    {
      "type":    "range",
      "id":      "overlay_opacity",
      "label":   "Overlay Opacity (%)",
      "min":     0,
      "max":     100,
      "step":    5,
      "default": 50
    },
    {
      "type":    "checkbox",
      "id":      "enable_gradient_overlay",
      "label":   "Enable Gradient Overlay",
      "default": true
    },
    {
      "type":    "text",
      "id":      "gradient_css",
      "label":   "Gradient CSS",
      "default": "linear-gradient(135deg, rgba(160,32,240,0.7) 0%, rgba(100,0,180,0.5) 50%, rgba(200,50,200,0.4) 100%)",
      "info":    "Any valid CSS gradient value"
    },
    {
      "type":    "range",
      "id":      "gradient_opacity",
      "label":   "Gradient Opacity (%)",
      "min":     0,
      "max":     100,
      "step":    5,
      "default": 70
    },

    {
      "type": "header",
      "content": "📐 Section Layout"
    },
    {
      "type":    "select",
      "id":      "text_alignment",
      "label":   "Text Alignment",
      "options": [
        { "value": "left",   "label": "Left"   },
        { "value": "center", "label": "Center" },
        { "value": "right",  "label": "Right"  }
      ],
      "default": "center"
    },
    {
      "type":    "range",
      "id":      "content_max_width",
      "label":   "Content Max Width (px)",
      "min":     400,
      "max":     1400,
      "step":    20,
      "default": 800
    },
    {
      "type":    "range",
      "id":      "content_padding_x",
      "label":   "Content Side Padding Desktop (px)",
      "min":     0,
      "max":     120,
      "step":    4,
      "default": 40
    },
    {
      "type":    "range",
      "id":      "content_padding_x_mobile",
      "label":   "Content Side Padding Mobile (px)",
      "min":     0,
      "max":     60,
      "step":    2,
      "default": 20
    },
    {
      "type":    "range",
      "id":      "min_height_desktop",
      "label":   "Min Height – Desktop (px)",
      "min":     200,
      "max":     1000,
      "step":    20,
      "default": 560
    },
    {
      "type":    "range",
      "id":      "min_height_tablet",
      "label":   "Min Height – Tablet (px)",
      "min":     200,
      "max":     900,
      "step":    20,
      "default": 480
    },
    {
      "type":    "range",
      "id":      "min_height_mobile",
      "label":   "Min Height – Mobile (px)",
      "min":     100,
      "max":     800,
      "step":    20,
      "default": 400
    },

    {
      "type": "header",
      "content": "📏 Section Padding"
    },
    {
      "type":    "range",
      "id":      "padding_top_desktop",
      "label":   "Padding Top – Desktop (px)",
      "min":     0,
      "max":     200,
      "step":    4,
      "default": 80
    },
    {
      "type":    "range",
      "id":      "padding_bottom_desktop",
      "label":   "Padding Bottom – Desktop (px)",
      "min":     0,
      "max":     200,
      "step":    4,
      "default": 80
    },
    {
      "type":    "range",
      "id":      "padding_top_tablet",
      "label":   "Padding Top – Tablet (px)",
      "min":     0,
      "max":     160,
      "step":    4,
      "default": 60
    },
    {
      "type":    "range",
      "id":      "padding_bottom_tablet",
      "label":   "Padding Bottom – Tablet (px)",
      "min":     0,
      "max":     160,
      "step":    4,
      "default": 60
    },
    {
      "type":    "range",
      "id":      "padding_top_mobile",
      "label":   "Padding Top – Mobile (px)",
      "min":     0,
      "max":     120,
      "step":    4,
      "default": 48
    },
    {
      "type":    "range",
      "id":      "padding_bottom_mobile",
      "label":   "Padding Bottom – Mobile (px)",
      "min":     0,
      "max":     120,
      "step":    4,
      "default": 48
    },

    {
      "type": "header",
      "content": "🏷️ Eyebrow / Pre-Title"
    },
    {
      "type":  "text",
      "id":    "eyebrow",
      "label": "Eyebrow Text",
    },
    {
      "type":    "color",
      "id":      "eyebrow_color",
      "label":   "Eyebrow Color",
      "default": "#ffffff"
    },
    {
      "type":    "range",
      "id":      "eyebrow_size",
      "label":   "Eyebrow Font Size (px)",
      "min":     10,
      "max":     24,
      "step":    1,
      "default": 13
    },

    {
      "type": "header",
      "content": "✏️ Heading"
    },
    {
      "type":    "text",
      "id":      "heading",
      "label":   "Heading Text",
      "default": "WHAT YOU WON'T FIND IN VERA"
    },
    {
      "type":    "select",
      "id":      "heading_tag",
      "label":   "Heading HTML Tag",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "p",  "label": "Paragraph" }
      ],
      "default": "h2"
    },
    {
      "type":    "color",
      "id":      "heading_color",
      "label":   "Heading Color",
      "default": "#ffffff"
    },
    {
      "type":    "range",
      "id":      "heading_size_desktop",
      "label":   "Heading Font Size – Desktop (px)",
      "min":     20,
      "max":     100,
      "step":    1,
      "default": 52
    },
