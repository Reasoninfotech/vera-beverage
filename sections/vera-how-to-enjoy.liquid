{% comment %}
  Vera - How To Enjoy Section
  Purple box: 9-position preset selector (top/center/bottom × left/center/right)
{% endcomment %}


{%- liquid
  assign section_id = 'mfc-' | append: section.id 
  assign btn_bg = section.settings.button_bg_color
  assign btn_text_color = section.settings.button_text_color
  assign btn_bg_hover = section.settings.button_bg_color_hover
  assign btn_text_hover_color = section.settings.button_text_color_hover
  assign btn_size_desktop = section.settings.button_font_size_desktop
  assign btn_size_mobile = section.settings.button_font_size_mobile
-%}

{%- style -%}

  {%- assign box_top = '50%' -%}
  {%- assign box_left = '50%' -%}
  {%- assign box_transform = 'translate(-50%, -50%)' -%}

  {%- case section.settings.box_position_desktop -%}
    {%- when 'top-left' -%}
      {%- assign box_top_d = '5%' -%}{%- assign box_left_d = '5%' -%}{%- assign box_transform_d = 'none' -%}
    {%- when 'top-center' -%}
      {%- assign box_top_d = '5%' -%}{%- assign box_left_d = '50%' -%}{%- assign box_transform_d = 'translateX(-50%)' -%}
    {%- when 'top-right' -%}
      {%- assign box_top_d = '5%' -%}{%- assign box_left_d = 'auto' -%}{%- assign box_right_d = '5%' -%}{%- assign box_transform_d = 'none' -%}
    {%- when 'center-left' -%}
      {%- assign box_top_d = '50%' -%}{%- assign box_left_d = '5%' -%}{%- assign box_transform_d = 'translateY(-50%)' -%}
    {%- when 'center-center' -%}
      {%- assign box_top_d = '50%' -%}{%- assign box_left_d = '50%' -%}{%- assign box_transform_d = 'translate(-50%, -50%)' -%}
    {%- when 'center-right' -%}
      {%- assign box_top_d = '50%' -%}{%- assign box_left_d = 'auto' -%}{%- assign box_right_d = '5%' -%}{%- assign box_transform_d = 'translateY(-50%)' -%}
    {%- when 'bottom-left' -%}
      {%- assign box_top_d = 'auto' -%}{%- assign box_bottom_d = '5%' -%}{%- assign box_left_d = '5%' -%}{%- assign box_transform_d = 'none' -%}
    {%- when 'bottom-center' -%}
      {%- assign box_top_d = 'auto' -%}{%- assign box_bottom_d = '5%' -%}{%- assign box_left_d = '50%' -%}{%- assign box_transform_d = 'translateX(-50%)' -%}
    {%- when 'bottom-right' -%}
      {%- assign box_top_d = 'auto' -%}{%- assign box_bottom_d = '5%' -%}{%- assign box_left_d = 'auto' -%}{%- assign box_right_d = '5%' -%}{%- assign box_transform_d = 'none' -%}
  {%- endcase -%}

  {%- case section.settings.box_position_tablet -%}
    {%- when 'top-left' -%}
      {%- assign box_top_t = '5%' -%}{%- assign box_left_t = '5%' -%}{%- assign box_transform_t = 'none' -%}
    {%- when 'top-center' -%}
      {%- assign box_top_t = '5%' -%}{%- assign box_left_t = '50%' -%}{%- assign box_transform_t = 'translateX(-50%)' -%}
    {%- when 'top-right' -%}
      {%- assign box_top_t = '5%' -%}{%- assign box_left_t = 'auto' -%}{%- assign box_right_t = '5%' -%}{%- assign box_transform_t = 'none' -%}
    {%- when 'center-left' -%}
      {%- assign box_top_t = '50%' -%}{%- assign box_left_t = '5%' -%}{%- assign box_transform_t = 'translateY(-50%)' -%}
    {%- when 'center-center' -%}
      {%- assign box_top_t = '50%' -%}{%- assign box_left_t = '50%' -%}{%- assign box_transform_t = 'translate(-50%, -50%)' -%}
    {%- when 'center-right' -%}
      {%- assign box_top_t = '50%' -%}{%- assign box_left_t = 'auto' -%}{%- assign box_right_t = '5%' -%}{%- assign box_transform_t = 'translateY(-50%)' -%}
    {%- when 'bottom-left' -%}
      {%- assign box_top_t = 'auto' -%}{%- assign box_bottom_t = '5%' -%}{%- assign box_left_t = '5%' -%}{%- assign box_transform_t = 'none' -%}
    {%- when 'bottom-center' -%}
      {%- assign box_top_t = 'auto' -%}{%- assign box_bottom_t = '5%' -%}{%- assign box_left_t = '50%' -%}{%- assign box_transform_t = 'translateX(-50%)' -%}
    {%- when 'bottom-right' -%}
      {%- assign box_top_t = 'auto' -%}{%- assign box_bottom_t = '5%' -%}{%- assign box_left_t = 'auto' -%}{%- assign box_right_t = '5%' -%}{%- assign box_transform_t = 'none' -%}
  {%- endcase -%}

  #shopify-section-{{ section.id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    min-height: {{ section.settings.section_min_height_desktop }}px;
  }

  .vera-enjoy__bg {
    position: absolute;
    inset: 0;
    background-image: url('{{ section.settings.background_image | image_url: width: 2000 }}');
    background-size: cover;
    background-position: {{ section.settings.bg_position }};
    background-repeat: no-repeat;
    z-index: 0;
  }
  .vera-enjoy__bg-overlay {
    position: absolute;
    inset: 0;
    background: {{ section.settings.bg_overlay_color }};
    opacity: {{ section.settings.bg_overlay_opacity | divided_by: 100.0 }};
    z-index: 1;
  }
  .vera-enjoy {
    padding-top: 60px;
    padding-bottom: 60px;
  }

  .vera-enjoy__inner {
    position: relative;
    z-index: 2;
    width: 100%;
    min-height: {{ section.settings.section_min_height_desktop }}px;
    max-width: 1230px;
    margin: 0 auto;
  }

  /* ── Desktop Box ── */
  .vera-enjoy__box {
    position: absolute;
    top: {{ box_top_d }};
    left: {{ box_left_d }};
    {%- if box_right_d -%}right: {{ box_right_d }};{%- endif -%}
    {%- if box_bottom_d -%}bottom: {{ box_bottom_d }};{%- endif -%}
    transform: {{ box_transform_d }};
    width: 100%;
    max-width: 430px;
    background: #8a2d7399;
    padding: 30px 20px;
    border-radius: 2px;
    overflow: hidden;
    z-index: 3;
  }

  .vera_enjoy__bubbles_wrp {
        text-align: center;
    width: 100%;
    max-width: 80px;
    margin: 0 auto;
    padding-bottom: 13px;
  }
  .vera-enjoy__bubbles {
    width: 110px;
    pointer-events: none;
    margin: 0 auto;
  }

  .vera-enjoy__title {
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.01em;
    line-height: 1.05;
    margin: 0 0 22px 0;
    color: {{ section.settings.title_color_desktop }};
    font-size: {{ section.settings.title_size_desktop }}px;
  }
  .vera-enjoy__content {
    font-family: 'Barlow', sans-serif;
    font-weight: 400;
    line-height: 1.65;
    margin: 0;
    color: {{ section.settings.content_color_desktop }};
    font-size: {{ section.settings.content_size_desktop }}px;
  }

   /* Button */
  #{{ section_id }} .mfc-btn-wrap {
    text-align: center;
    margin-top: 25px;
  }

  #{{ section_id }} .mfc-btn {
    display: inline-block;
    background: {{ btn_bg }};
    color: {{ btn_text_color }};
    font-size: {{ btn_size_desktop }}px;
    text-transform: uppercase;
    padding: 12px 40px;
    text-decoration: none;
    transition: background 0.2s, color 0.2s;
    border-radius: 2px;
  }

  #{{ section_id }} .mfc-btn:hover {
    background: {{ btn_bg_hover }};
    color: {{ btn_text_hover_color }};
  }


  /* ── Tablet ── */
  @media screen and (max-width: 1024px) {
    #shopify-section-{{ section.id }},
    .vera-enjoy__inner {
      min-height: {{ section.settings.section_min_height_tablet }}px;
    }
    .vera-enjoy__box {
      top: {{ box_top_t }};
      left: {{ box_left_t }};
      right: {%- if box_right_t -%}{{ box_right_t }}{%- else -%}auto{%- endif -%};
      bottom: {%- if box_bottom_t -%}{{ box_bottom_t }}{%- else -%}auto{%- endif -%};
      transform: {{ box_transform_t }};
    }
    .vera-enjoy__title {
      font-size: {{ section.settings.title_size_tablet }}px;
      color: {{ section.settings.title_color_tablet }};
    }
    .vera-enjoy__content {
      font-size: {{ section.settings.content_size_tablet }}px;
      color: {{ section.settings.content_color_tablet }};
    }
  }

  /* ── Mobile ── */
  @media screen and (max-width: 767px) {
    #shopify-section-{{ section.id }} { min-height: unset; }
    .vera-enjoy__inner {
      min-height: unset;
      padding: {{ section.settings.section_padding_mobile }}px {{ section.settings.section_padding_h_mobile }}px;
    }
    .vera-enjoy__box {
      position: relative;
      top: auto; left: auto; right: auto; bottom: auto;
      transform: none;
      width: 100%;
      padding: 30px 20px;
    }
    .vera-enjoy__title {
      font-size: {{ section.settings.title_size_mobile }}px;
      color: {{ section.settings.title_color_mobile }};
    }
    .vera-enjoy__content {
      font-size: {{ section.settings.content_size_mobile }}px;
      color: {{ section.settings.content_color_mobile }};
    }
    .vera-enjoy__bubbles { width: 80px; }

    #{{ section_id }} .mfc-btn-wrap {
     margin-top: 15px;
    }

     #{{ section_id }} .mfc-btn {
      font-size: {{ btn_size_mobile }}px;
      padding: 14px 28px;
    }
    .vera-enjoy__bg {
    position: absolute;
    inset: 0;
    background-image: url('{{ section.settings.background_image_mobile | image_url: width: 2000 }}');
    background-size: cover;
    background-position: {{ section.settings.bg_position }};
    background-repeat: no-repeat;
    z-index: 0;
  }

  }
   @media screen and (max-width: 575px) {
    .vera_enjoy__bubbles_wrp {
display: none;
    }
    .vera-enjoy__box {
      max-width: 285px;
    }
   }
{%- endstyle -%}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Barlow:wght@400;500&family=Barlow+Condensed:wght@700&display=swap" rel="stylesheet">

<div id="{{ section_id }}" class="vera-enjoy">
  <div class="vera-enjoy__bg" aria-hidden="true"></div>
  <div class="vera-enjoy__bg-overlay" aria-hidden="true"></div>

  <div class="vera-enjoy__inner">
    <div class="vera-enjoy__box">

      <div class="vera_enjoy__bubbles_wrp">
        {% comment %} <svg class="vera-enjoy__bubbles" viewBox="0 0 110 120" fill="none"
  xmlns="http://www.w3.org/2000/svg" aria-hidden="true">

  <defs>
    <style><![CDATA[

      circle {
        transform-box: fill-box;
        transform-origin: center;
        animation: float 6s ease-in-out infinite, glow 3s ease-in-out infinite;
      }

      circle:nth-of-type(1) { animation-duration: 6s, 3s; }
      circle:nth-of-type(2) { animation-duration: 5s, 2.8s; }
      circle:nth-of-type(3) { animation-duration: 4.5s, 2.5s; }
      circle:nth-of-type(4) { animation-duration: 4s, 2.2s; }
      circle:nth-of-type(5) { animation-duration: 3.5s, 2s; }
      circle:nth-of-type(6) { animation-duration: 5.5s, 2.6s; }

      @keyframes float {
        0%   { transform: translateY(0px); }
        50%  { transform: translateY(-12px); }
        100% { transform: translateY(0px); }
      }

      @keyframes glow {
        0%   { filter: drop-shadow(0 0 2px rgba(255,255,255,0.4)); }
        50%  { filter: drop-shadow(0 0 8px rgba(255,255,255,0.8)); }
        100% { filter: drop-shadow(0 0 2px rgba(255,255,255,0.4)); }
      }

    ]]></style>
  </defs>

  <circle cx="82" cy="18" r="12" stroke="rgba(255,255,255,0.55)" stroke-width="1.5" fill="none"/>
  <circle cx="58" cy="42" r="8" stroke="rgba(255,255,255,0.45)" stroke-width="1.3" fill="none"/>
  <circle cx="90" cy="55" r="5" stroke="rgba(255,255,255,0.38)" stroke-width="1.2" fill="none"/>
  <circle cx="70" cy="68" r="3" stroke="rgba(255,255,255,0.30)" stroke-width="1"/>
  <circle cx="95" cy="78" r="2.2" stroke="rgba(255,255,255,0.28)" stroke-width="1"/>
  <circle cx="50" cy="22" r="4" stroke="rgba(255,255,255,0.32)" stroke-width="1"/>

</svg> {% endcomment %}
<img src="https://cdn.shopify.com/s/files/1/0814/7668/1964/files/Vera_Bubble_Vector.png?v=1771995568" />
      </div>

      {%- if section.settings.title != blank -%}
        <h2 class="vera-enjoy__title">{{ section.settings.title }}</h2>
      {%- endif -%}
      {%- if section.settings.content != blank -%}
        <p class="vera-enjoy__content">{{ section.settings.content }}</p>
      {%- endif -%}

      {%- if section.settings.button_url != blank -%}
        <div class="mfc-btn-wrap">
          <a href="{{ section.settings.button_url | default: '#' }}" class="mfc-btn">
            {{ section.settings.button_text }}
          </a>
        </div>
      {%- endif -%}


    </div>
  </div>
</div>

{% schema %}
{
  "name": "Vera How To Enjoy",
  "tag": "section",
  "class": "vera-how-to-enjoy-section",
  "settings": [

    { "type": "header", "content": "🖼 Background Image" },
    { "type": "image_picker", "id": "background_image", "label": "Background image Desktop" },
    { "type": "image_picker", "id": "background_image_mobile", "label": "Background image Mobile" },
    {
      "type": "select", "id": "bg_position", "label": "Image position", "default": "center center",
      "options": [
        { "value": "top left",      "label": "Top Left" },
        { "value": "top center",    "label": "Top Center" },
        { "value": "top right",     "label": "Top Right" },
        { "value": "center left",   "label": "Center Left" },
        { "value": "center center", "label": "Center Center" },
        { "value": "center right",  "label": "Center Right" },
        { "value": "bottom left",   "label": "Bottom Left" },
        { "value": "bottom center", "label": "Bottom Center" },
        { "value": "bottom right",  "label": "Bottom Right" }
      ]
    },
    { "type": "color", "id": "bg_overlay_color",  "label": "Overlay color",       "default": "#000000" },
    { "type": "range", "id": "bg_overlay_opacity", "label": "Overlay opacity (%)", "min": 0, "max": 90, "step": 5, "default": 20 },

    { "type": "header", "content": "📝 Content" },
    { "type": "text",     "id": "title",   "label": "Title",     "default": "HOW TO ENJOY VERA." },
    { "type": "textarea", "id": "content", "label": "Body text", "default": "Enjoy Vera chilled, anytime you want to feel good and stay clear-headed. It's designed to fit effortlessly into your day — whether you're powering through focused work, easing into creative flow, or choosing a smarter social sip with friends. Lightly sparkling, refreshing, and easygoing, Vera is a daily ritual reimagined — meant to be enjoyed your way, in whatever moment you find yourself." },

    { "type": "header", "content": "📌 Purple Box Position – Desktop" },
    {
      "type": "select", "id": "box_position_desktop", "label": "Box position (Desktop)", "default": "center-left",
      "options": [
        { "value": "top-left",      "label": "⬆⬅  Top – Left" },
        { "value": "top-center",    "label": "⬆⬛  Top – Center" },
        { "value": "top-right",     "label": "⬆➡  Top – Right" },
        { "value": "center-left",   "label": "⬛⬅  Center – Left" },
        { "value": "center-center", "label": "⬛⬛  Center – Center" },
        { "value": "center-right",  "label": "⬛➡  Center – Right" },
        { "value": "bottom-left",   "label": "⬇⬅  Bottom – Left" },
        { "value": "bottom-center", "label": "⬇⬛  Bottom – Center" },
        { "value": "bottom-right",  "label": "⬇➡  Bottom – Right" }
      ]
    },

    { "type": "header", "content": "📌 Purple Box Position – Tablet" },
    {
      "type": "select", "id": "box_position_tablet", "label": "Box position (Tablet)", "default": "center-left",
      "options": [
        { "value": "top-left",      "label": "⬆⬅  Top – Left" },
        { "value": "top-center",    "label": "⬆⬛  Top – Center" },
        { "value": "top-right",     "label": "⬆➡  Top – Right" },
        { "value": "center-left",   "label": "⬛⬅  Center – Left" },
        { "value": "center-center", "label": "⬛⬛  Center – Center" },
        { "value": "center-right",  "label": "⬛➡  Center – Right" },
        { "value": "bottom-left",   "label": "⬇⬅  Bottom – Left" },
        { "value": "bottom-center", "label": "⬇⬛  Bottom – Center" },
        { "value": "bottom-right",  "label": "⬇➡  Bottom – Right" }
      ]
    },

    { "type": "header", "content": "🖥 Desktop – Title" },
    { "type": "color", "id": "title_color_desktop", "label": "Title color",    "default": "#FFFFFF" },
    { "type": "range", "id": "title_size_desktop",  "label": "Font size (px)", "min": 24, "max": 80, "step": 1, "default": 46 },

    { "type": "header", "content": "🖥 Desktop – Content" },
    { "type": "color", "id": "content_color_desktop", "label": "Content color",  "default": "#F0E6EE" },
    { "type": "range", "id": "content_size_desktop",  "label": "Font size (px)", "min": 12, "max": 28, "step": 1, "default": 16 },

    { "type": "header", "content": "💻 Tablet – Title" },
    { "type": "color", "id": "title_color_tablet", "label": "Title color",    "default": "#FFFFFF" },
    { "type": "range", "id": "title_size_tablet",  "label": "Font size (px)", "min": 20, "max": 72, "step": 1, "default": 38 },

    { "type": "header", "content": "💻 Tablet – Content" },
    { "type": "color", "id": "content_color_tablet", "label": "Content color",  "default": "#F0E6EE" },
    { "type": "range", "id": "content_size_tablet",  "label": "Font size (px)", "min": 12, "max": 26, "step": 1, "default": 15 },

    { "type": "header", "content": "📱 Mobile – Title" },
    { "type": "color", "id": "title_color_mobile", "label": "Title color",    "default": "#FFFFFF" },
    { "type": "range", "id": "title_size_mobile",  "label": "Font size (px)", "min": 18, "max": 56, "step": 1, "default": 32 },

    { "type": "header", "content": "📱 Mobile – Content" },
    { "type": "color", "id": "content_color_mobile", "label": "Content color",  "default": "#F0E6EE" },
    { "type": "range", "id": "content_size_mobile",  "label": "Font size (px)", "min": 12, "max": 22, "step": 1, "default": 14 },

    { "type": "header", "content": "📐 Section Height" },
    { "type": "range", "id": "section_min_height_desktop", "label": "Height – Desktop (px)", "min": 300, "max": 900, "step": 10, "default": 580 },
    { "type": "range", "id": "section_min_height_tablet",  "label": "Height – Tablet (px)",  "min": 200, "max": 800, "step": 10, "default": 460 },
    { "type": "range", "id": "section_min_height_mobile",  "label": "Min height – Mobile (px)", "min": 0, "max": 600, "step": 10, "default": 0 },

    { "type": "header", "content": "📐 Mobile Padding" },
    { "type": "range", "id": "section_padding_mobile",   "label": "Vertical padding (px)",   "min": 0, "max": 80, "step": 4, "default": 32 },
    { "type": "range", "id": "section_padding_h_mobile", "label": "Horizontal padding (px)", "min": 0, "max": 60, "step": 4, "default": 16 },

    { "type": "header", "content": "Button" },
    { "type": "text", "id": "button_text", "label": "Button Text", "default": "FIND OUT MORE" },
    { "type": "url", "id": "button_url", "label": "Button URL" },
    { "type": "color", "id": "button_bg_color", "label": "Button Background Color", "default": "#d4145a"},
    { "type": "color", "id": "button_text_color", "label": "Button Text Color", "default": "#ffffff" },
    { "type": "color", "id": "button_bg_color_hover", "label": "Button Background Hover Color", "default": "#d4145a" },
    { "type": "color", "id": "button_text_color_hover", "label": "Button Text Hover Color", "default": "#ffffff" },
    { "type": "range", "id": "button_font_size_desktop", "label": "Button Font Size (Desktop)", "min": 10, "max": 24, "step": 1, "unit": "px", "default": 14 },
    { "type": "range", "id": "button_font_size_mobile", "label": "Button Font Size (Mobile)", "min": 10, "max": 20, "step": 1, "unit": "px", "default": 13 }

  ],
  "presets": [{ "name": "Vera How To Enjoy" }]
}
{% endschema %}
