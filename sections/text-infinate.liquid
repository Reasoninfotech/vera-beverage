{% style %}

.marquee_logo {
  padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
}

.marquee {
  width: 100%;
  overflow: hidden;
  position: relative;
  display: flex;
}

.marquee_logo .marquee__inner {
  display: flex;
  align-items: center;
  gap: {{ section.settings.desktop_gap }}px;
  width: max-content;
  animation: marquee {{ section.settings.desktop_speed }}s linear infinite;
  white-space: nowrap;
}

.marquee_logo .marquee__inner:hover {
  animation-play-state: paused;
}

.marquee__inner .image_bar__link_svg {
  line-height: normal;
  margin: 0;
  display: flex;
  align-items: center;
  gap: {{ section.settings.desktop_gap }}px;
}

.marquee__inner img {
  width: 100%;
  max-width: {{ section.settings.desktop_icon_size }}px;
  height: auto;
  object-fit: cover;
}

.text_infinate {
  display: block;
  font-size: {{ section.settings.desktop_font_size }}px;
  line-height: normal;
  font-weight: 400;
  font-family: var(--rift);
}

@keyframes marquee {
  from { transform: translateX(0); }
  to { transform: translateX(-50%); }
}

/* Tablet */
@media (max-width: 1024px) and (min-width: 576px) {
  .text_infinate {
    font-size: {{ section.settings.tablet_font_size }}px;
  }
  .marquee_logo .marquee__inner {
    animation-duration: {{ section.settings.tablet_speed }}s;
    gap: {{ section.settings.tablet_gap }}px;
  }
  .marquee__inner .image_bar__link_svg {
    gap: {{ section.settings.tablet_gap }}px;
  }
  .marquee__inner img {
    max-width: {{ section.settings.tablet_icon_size }}px;
  }

  .marquee_logo {
    padding: {{ section.settings.padding_top_tablet }}px 0 {{ section.settings.padding_bottom_tablet }}px;
  }

}

/* Mobile */
@media (max-width: 575px) {
  .text_infinate {
    font-size: {{ section.settings.mobile_font_size }}px;
  }
  .marquee_logo .marquee__inner {
    animation-duration: {{ section.settings.mobile_speed }}s;
    gap: {{ section.settings.mobile_gap }}px;
  }
  .marquee__inner .image_bar__link_svg {
    gap: {{ section.settings.mobile_gap }}px;
  }
  .marquee__inner img {
    max-width: {{ section.settings.mobile_icon_size }}px;
  }

  .marquee_logo {
    padding: {{ section.settings.padding_top_mobile }}px 0 {{ section.settings.padding_bottom_mobile }}px;
  }

}

{% endstyle %}

<section class="marquee_logo" style="background: {{ section.settings.body_background }};">
  <div class="marquee">
    <div class="marquee__inner-wrap">
      <div class="marquee__inner">
        {% for block in section.blocks %}
          {% for i in (1..10) %}
            <div class="image_bar__link_svg">
              {% if block.settings.logos != blank %}
                <div class="img_block">
                  <img
                    decoding="async"
                    src="{{ block.settings.logos | img_url }}"
                    alt="{{ block.settings.logos.alt }}"
                    loading="lazy"
                  >
                </div>
              {% endif %}
              <span class="text_infinate" style="color: {{ section.settings.body_text }}">{{ block.settings.title }}</span>
            </div>
          {% endfor %}
        {% endfor %}
      </div>
    </div>
  </div>
</section>

